{
  "name": "@echo-chamber/app-cloudflare-workers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "dev": "wrangler types --config wrangler.jsonc && wrangler dev --config wrangler.jsonc",
    "start": "wrangler dev --config wrangler.jsonc",
    "cf-typegen": "wrangler types --config wrangler.jsonc",
    "test": "vitest --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "tdd": "vitest --watch --ui --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@echo-chamber/core": "workspace:*",
    "hono": "4.7.11",
    "openai": "5.23.2",
    "zod": "4.0.5"
  }
}
