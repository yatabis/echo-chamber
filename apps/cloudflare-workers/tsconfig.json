{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": [
      "./worker-configuration.d.ts",
      "@cloudflare/vitest-pool-workers",
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.d.ts",
    "worker-configuration.d.ts",
    "vitest.config.ts"
  ]
}
