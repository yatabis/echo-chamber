{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2021", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "module": "es2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@echo-chamber/core": ["packages/core/src/index.ts"],
      "@echo-chamber/core/*": ["packages/core/src/*"],
      "@echo-chamber/contracts": ["packages/contracts/src/index.ts"],
      "@echo-chamber/contracts/*": ["packages/contracts/src/*"],
      "@echo-chamber/openai-adapter": ["packages/openai-adapter/src/index.ts"],
      "@echo-chamber/openai-adapter/*": ["packages/openai-adapter/src/*"],
      "@echo-chamber/discord-adapter": [
        "packages/discord-adapter/src/index.ts"
      ],
      "@echo-chamber/discord-adapter/*": ["packages/discord-adapter/src/*"],
      "@echo-chamber/cloudflare-runtime": [
        "packages/cloudflare-runtime/src/index.ts"
      ],
      "@echo-chamber/cloudflare-runtime/*": [
        "packages/cloudflare-runtime/src/*"
      ]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "build", "coverage", "html"]
}
