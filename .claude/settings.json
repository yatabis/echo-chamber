{
  "permissions": {
    "allow": [
      "Bash(pnpm dev)",
      "Bash(pnpm install)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test:run:*)",
      "Bash(pnpm test:coverage)",
      "mcp__ide__getDiagnostics",
      "mcp__eslint",
      "mcp__cloudflare-docs",
      "mcp__cloudflare-observability",
      "mcp__cloudflare-browser",
      "mcp__typescript",
      "mcp__playwright"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.' >> notifications.jsonl && pnpm lint && pnpm format && pnpm typecheck"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true
}
